<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('../nav') %>
    <div class="browse">
        <h2>Select Game</h2>
        <ul>
            <% games.forEach((game) => { %>
                <li><a href="games/<%= game.id %>"><%= game.name %></a></li>
            <% }); %>
        </ul>
    </div>
</body>
</html>