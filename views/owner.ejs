<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('nav') %>
    <div class="owner">
        <div>
            <h1><%= owner.name %></h1>
            <form action="/owners/edit/<%= owner.id %>" method="GET" >
                <button>Edit</button>
            </form>
            <form action="/owners/delete" method="POST" >
                <input type="hidden" name="ownerId" value="<%= owner.id %>">
                <button>Delete</button>
            </form>
        </div>
        <img src="<%= owner.image_url %>" alt="<%= owner.name %>">
        <p>Occupation: <%= owner.occupation %></p>
        <div class="evidenceCards">
            <% evidences.forEach((evidence) => { %>
                <%- include('evidenceCard', {evidence: evidence}); %>
            <% }); %>
        </div>
    </div>
</body>
</html>