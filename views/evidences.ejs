<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('nav') %>
    <div class="evidences">
        <h1>All Evidence</h1>
        <div class="evidenceCards">
            <% evidences.forEach((evidence) => { %>
                <%- include('evidenceCard', {evidence: evidence}); %>
            <% }); %>
        </div>
    </div>
</body>
</html>